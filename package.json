{
  "name": "academic-command-center",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx --env-file=.env.local --watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@hono/node-server": "^2.0.2",
    "@supabase/supabase-js": "^2.105.4",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "hono": "^4.12.18",
    "lucide-react": "^0.475.0",
    "mammoth": "^1.12.0",
    "node-ical": "^0.26.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.21.0",
    "vite": "^6.1.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/web-push": "^3.6.4",
    "typescript": "^5.7.3"
  }
}
