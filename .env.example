# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase project credentials
# Project URL: Supabase Dashboard -> Project Settings -> API -> Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Optional server alias. Leave equal to VITE_SUPABASE_URL unless you have a reason to separate them.
SUPABASE_URL=https://your-project-ref.supabase.co

# Browser-safe anon public key: Supabase Dashboard -> Project Settings -> API -> anon public
# This is used by the React app with Row Level Security enabled.
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server-only service role key: Supabase Dashboard -> Project Settings -> API -> service_role secret
# Never expose this in frontend code and never prefix it with VITE_.
# Use only in trusted server routes that need elevated database access.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key for syllabus parsing (Haiku 4.5)
# Get one: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Canvas LMS base URL (no trailing slash)
# Example: https://canvas.instructure.com or https://gatech.instructure.com
CANVAS_BASE_URL=https://your-school.instructure.com

# Canvas Personal Access Token (read-only scope)
# Generate: <CANVAS_BASE_URL>/profile/settings -> "+ New Access Token"
CANVAS_PAT=

# Brightspace / iCollege (D2L) iCalendar feed URL
# iCollege has no personal API token. Use the per-user calendar feed instead:
#   iCollege -> Calendar -> Subscribe -> copy URL (webcal:// or https://...ics)
# Server fetches this URL, parses VEVENTs into assignments.
ICOLLEGE_ICS_URL=
# Optional: model override (default claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: max syllabus tokens to send (truncate long PDFs)
# SYLLABUS_MAX_INPUT_TOKENS=15000

# Public origin used in notification links
APP_ORIGIN=http://localhost:5173

# Web Push / PWA notifications
# Generate with: npx web-push generate-vapid-keys
VITE_WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com

# Email reminders through Resend
RESEND_API_KEY=
EMAIL_FROM="Lazy <reminders@example.com>"
EMAIL_FALLBACK_FOR_PUSH=true

# Secret for your deployed cron job to call POST /api/notifications/run-due
NOTIFICATION_CRON_SECRET=
NOTIFICATION_BATCH_SIZE=100
NOTIFICATION_LOOKBACK_MINUTES=360
